# ════════════════════════════════════════════════════════════════
# Vela · environment variables
# Copie este arquivo para .env (NÃO commitar o .env real, já está
# no .gitignore via .env*) e preencha os valores.
# ════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
# Pegue em Supabase → Project Settings → Database → Connection string
# Use a "Transaction" pooler (porta 6543) para Vercel/serverless;
# ou a "Session" (porta 5432) para dev local.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public"

# ── NextAuth ────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="trocar-por-uma-string-longa-aleatoria"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth providers (todos opcionais) ───────────────────────────
# Se deixar em branco, o provider não aparece na tela /entrar.
# Pode ligar um, dois, ou todos quando quiser.

# Google: Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft: Azure Portal → App Registrations → New registration
# Redirect URI (Web): http://localhost:3000/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# ── Email (Resend) ──────────────────────────────────────────────
# https://resend.com → API Keys (free tier: 100/dia, 3k/mês)
# Se deixar em branco, emails caem em console.log (útil pra dev sem conta).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Vela <onboarding@vela.com.br>"
# Para onde notificar quando lead novo chega:
LEAD_NOTIFICATION_EMAIL="vendas@vela.com.br"

# ── Vela admin seed (apenas pra primeiro setup) ─────────────────
# Email que vira VELA_ADMIN no primeiro `prisma db seed`.
# Use seu email pra você acessar /admin depois.
SEED_ADMIN_EMAIL="admin@suaclinica.com.br"
SEED_ADMIN_NAME="Seu Nome"
# Senha inicial; troque depois pelo painel.
SEED_ADMIN_PASSWORD="muda-essa-senha-imediatamente"
