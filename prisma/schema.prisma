// Vela — Prisma schema
// ──────────────────────────────────────────────────────────────────
// Modela: contas NextAuth, multi-tenancy (Clinic + Membership),
// leads do funil de venda, convites, pacientes e atendimentos básicos,
// assinatura (placeholder pra Stripe) e log de auditoria pra LGPD.
//
// Comandos úteis:
//   npx prisma migrate dev --name init    # cria as tabelas
//   npx prisma db seed                    # popula admin user
//   npx prisma studio                     # GUI pra explorar dados

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url vem de prisma.config.ts (Prisma 7+) via process.env.DATABASE_URL
}

// ══════════════════════════════════════════════════════════════════
// NextAuth core (https://authjs.dev/reference/adapter/prisma)
// ══════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ══════════════════════════════════════════════════════════════════
// Vela domain
// ══════════════════════════════════════════════════════════════════

/// Vela team members have role = "VELA_ADMIN".
/// Clinic users have role = "CUSTOMER" + a Membership per Clinic.
enum UserRole {
  VELA_ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash; null se usuário só usa magic link ou OAuth
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  approvedLeads Lead[]       @relation("LeadApprover")
  sentInvites   Invite[]     @relation("InviteSender")
  auditLogs     AuditLog[]
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  cnpj      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  invites       Invite[]
  patients      Patient[]
  appointments  Appointment[]
  professionals Professional[]
  procedures    Procedure[]
  conversations Conversation[]
  subscription  Subscription?
  auditLogs     AuditLog[]
}

enum MembershipRole {
  ADMIN // dono / sócio
  MANAGER // gerente
  RECEPTIONIST // recepção
  FINANCE // financeiro
  PROFESSIONAL // médico, esteticista, fisio
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  clinicId  String
  role      MembershipRole @default(PROFESSIONAL)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
}

// ── Leads (formulário /contratar) ─────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
}

enum LeadPlan {
  ESSENCIAL
  CLINICA
  REDE
  UNDECIDED
}

model Lead {
  id        String     @id @default(cuid())
  nome      String
  sobrenome String
  whatsapp  String
  email     String
  cargo     String
  clinica   String
  plano     LeadPlan   @default(UNDECIDED)
  status    LeadStatus @default(NEW)
  /// notas internas da equipe Vela
  notes     String?    @db.Text

  approvedById String?
  approvedAt   DateTime?
  approver     User?     @relation("LeadApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Invites (criados na aprovação de lead) ───────────────────────

model Invite {
  id          String         @id @default(cuid())
  /// token aleatório usado em /registrar?token=…
  token       String         @unique
  email       String
  clinicId    String
  role        MembershipRole @default(ADMIN)
  expiresAt   DateTime
  usedAt      DateTime?
  invitedById String?

  clinic    Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── Profissionais ────────────────────────────────────────────────

model Professional {
  id       String  @id @default(cuid())
  clinicId String
  name     String
  role     String // ex: "Dermatologista", "Esteticista"
  /// hex sem #, ex "2A6062" — usado no card da agenda.
  /// Valores permitidos vivem em src/app/painel/configuracoes/profissionais/lib/schema.ts (PROFESSIONAL_PALETTE).
  color    String  @default("2A6062")
  active   Boolean @default(true)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, active])
}

// ── Procedimentos (tabela de preços) ────────────────────────────

model Procedure {
  id          String  @id @default(cuid())
  clinicId    String
  name        String
  durationMin Int     @default(60)
  /// preço em reais (não centavos); usamos Decimal pra evitar float drift
  priceBRL    Decimal @default(0) @db.Decimal(10, 2)
  active      Boolean @default(true)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, active])
}

// ── Pacientes (escopo MVP, expand depois) ────────────────────────

enum PatientTag {
  VIP
  ATIVO
  NOVO
  INATIVO
}

model Patient {
  id        String     @id @default(cuid())
  clinicId  String
  name      String
  email     String?
  /// E.164 quando possível
  phone     String?
  cpf       String?
  birthDate DateTime?
  tag       PatientTag @default(NOVO)
  notes     String?    @db.Text

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([clinicId, tag])
  @@index([clinicId, phone])
}

// ── Agendamentos (escopo MVP) ────────────────────────────────────

enum AppointmentStatus {
  CONFIRMADO
  PENDENTE
  ATENDIDO
  CANCELADO
  AUSENTE
}

model Appointment {
  id             String            @id @default(cuid())
  clinicId       String
  patientId      String
  professionalId String?
  procedureId    String
  startsAt       DateTime
  durationMin    Int               @default(60)
  status         AppointmentStatus @default(PENDENTE)
  /// preço cobrado nesse atendimento (pode divergir da tabela do Procedure)
  priceBRL       Decimal?          @db.Decimal(10, 2)
  notes          String?           @db.Text

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  procedure    Procedure     @relation(fields: [procedureId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, startsAt])
  @@index([patientId])
  @@index([professionalId])
}

// ── Conversas WhatsApp (Júlia) ───────────────────────────────────

enum MessageSender {
  JULIA
  PATIENT
  HUMAN
}

model Conversation {
  id            String   @id @default(cuid())
  clinicId      String
  patientId     String
  /// preview da última mensagem (denormalizado pra lista lateral)
  lastPreview   String   @default("")
  lastMessageAt DateTime @default(now())
  unread        Int      @default(0)

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, lastMessageAt])
  @@index([patientId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  sender         MessageSender
  text           String        @db.Text
  sentAt         DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
}

// ── Subscription (placeholder, ligar Stripe depois) ──────────────

enum SubscriptionPlan {
  TRIAL
  ESSENCIAL
  CLINICA
  REDE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model Subscription {
  id                   String             @id @default(cuid())
  clinicId             String             @unique
  plan                 SubscriptionPlan   @default(TRIAL)
  status               SubscriptionStatus @default(TRIAL)
  /// IDs do Stripe quando for ligado
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Audit log (LGPD compliance basics) ───────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  clinicId     String?
  action       String // ex: "lead.create", "lead.approve", "user.login"
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
