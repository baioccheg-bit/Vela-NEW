// Vela — Prisma schema
// ──────────────────────────────────────────────────────────────────
// Modela: contas NextAuth, multi-tenancy (Clinic + Membership),
// leads do funil de venda, convites, pacientes e atendimentos básicos,
// assinatura (placeholder pra Stripe) e log de auditoria pra LGPD.
//
// Comandos úteis:
//   npx prisma migrate dev --name init    # cria as tabelas
//   npx prisma db seed                    # popula admin user
//   npx prisma studio                     # GUI pra explorar dados

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url vem de prisma.config.ts (Prisma 7+) via process.env.DATABASE_URL
}

// ══════════════════════════════════════════════════════════════════
// NextAuth core (https://authjs.dev/reference/adapter/prisma)
// ══════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ══════════════════════════════════════════════════════════════════
// Vela domain
// ══════════════════════════════════════════════════════════════════

/// Vela team members have role = "VELA_ADMIN".
/// Clinic users have role = "CUSTOMER" + a Membership per Clinic.
enum UserRole {
  VELA_ADMIN
  CUSTOMER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash; null se usuário só usa magic link ou OAuth
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  /// timestamp em que o usuário fechou o modal de boas-vindas (tour ou pular).
  /// null = nunca viu, modal aparece no próximo acesso ao /painel.
  welcomedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  approvedLeads Lead[]       @relation("LeadApprover")
  sentInvites   Invite[]     @relation("InviteSender")
  auditLogs     AuditLog[]
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  cnpj      String?
  /// timestamp em que a clínica fechou o checklist de onboarding.
  /// null = checklist visível (se houver pendências). Não-null = oculto explicitamente.
  /// O checklist também some sozinho quando todos os itens ATIVOS estão concluídos.
  onboardingDismissedAt DateTime?
  /// timestamp da primeira vez que o admin salvou horários customizados (Fase 2.6).
  /// null = ainda usando defaults do seed → checklist mostra "Personalizar horários" pendente.
  /// Set pelo updateBusinessHours na primeira execução; nunca limpado pela UI.
  businessHoursCustomizedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  invites       Invite[]
  patients      Patient[]
  appointments  Appointment[]
  professionals Professional[]
  procedures    Procedure[]
  conversations Conversation[]
  subscription  Subscription?
  auditLogs     AuditLog[]
  businessHours BusinessHours[]
}

enum MembershipRole {
  ADMIN // dono / sócio
  MANAGER // gerente
  RECEPTIONIST // recepção
  FINANCE // financeiro
  PROFESSIONAL // médico, esteticista, fisio
}

/// Dias da semana em ordem cronológica (Segunda → Domingo).
/// Ordem importa: `ORDER BY weekday` em queries devolve a semana em ordem natural
/// pra UI sem mapeamento manual. Não usar 0-6 numérico — enum nominal é mais
/// legível em queries do Studio e nos logs do Júlia (Fase 4).
/// BUILD_PLAN.md linha 251 diz "weekday (0-6)" — desvio aceito nesta fase.
enum Weekday {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  clinicId  String
  role      MembershipRole @default(PROFESSIONAL)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
}

// ── Leads (formulário /contratar) ─────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
}

enum LeadPlan {
  ESSENCIAL
  CLINICA
  REDE
  UNDECIDED
}

model Lead {
  id        String     @id @default(cuid())
  nome      String
  sobrenome String
  whatsapp  String
  email     String
  cargo     String
  clinica   String
  plano     LeadPlan   @default(UNDECIDED)
  status    LeadStatus @default(NEW)
  /// notas internas da equipe Vela
  notes     String?    @db.Text

  approvedById String?
  approvedAt   DateTime?
  approver     User?     @relation("LeadApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ── Invites (criados na aprovação de lead) ───────────────────────

model Invite {
  id          String         @id @default(cuid())
  /// token aleatório usado em /registrar?token=…
  token       String         @unique
  email       String
  clinicId    String
  role        MembershipRole @default(ADMIN)
  expiresAt   DateTime
  usedAt      DateTime?
  invitedById String?

  clinic    Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invitedBy User?  @relation("InviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── Profissionais ────────────────────────────────────────────────

model Professional {
  id       String  @id @default(cuid())
  clinicId String
  name     String
  role     String // ex: "Dermatologista", "Esteticista"
  /// hex sem #, ex "2A6062" — usado no card da agenda.
  /// Valores permitidos vivem em src/app/painel/configuracoes/profissionais/lib/schema.ts (PROFESSIONAL_PALETTE).
  color    String  @default("2A6062")
  active   Boolean @default(true)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, active])
}

// ── Procedimentos (tabela de preços) ────────────────────────────

model Procedure {
  id          String  @id @default(cuid())
  clinicId    String
  name        String
  durationMin Int     @default(60)
  /// preço em reais (não centavos); usamos Decimal pra evitar float drift
  priceBRL    Decimal @default(0) @db.Decimal(10, 2)
  active      Boolean @default(true)

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, active])
}

// ── Horários de funcionamento (Fase 2.6) ─────────────────────────

/// Horário de uma clínica para um dia da semana.
/// Sempre 7 registros por Clinic (um por Weekday) — o seed/UI garantem.
/// Quando `active = false` o dia é fechado, mas opensAt/closesAt continuam
/// preenchidos por consistência: a regex e o refine do Zod exigem sempre
/// HH:mm válido com opensAt < closesAt, mesmo em dia fechado, pra evitar
/// dado inconsistente persistido.
/// A Júlia (Fase 4) lê esta tabela pra validar disponibilidade antes de
/// propor slot ao paciente.
model BusinessHours {
  id       String  @id @default(cuid())
  clinicId String
  weekday  Weekday
  /// formato "HH:mm" 24h, ex "08:00". Regex validada na Server Action.
  opensAt  String
  /// idem opensAt. Refine garante opensAt < closesAt sempre.
  closesAt String
  active   Boolean @default(true)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, weekday])
  @@index([clinicId])
}

// ── Pacientes (escopo MVP, expand depois) ────────────────────────

enum PatientTag {
  VIP
  ATIVO
  NOVO
  INATIVO
}

model Patient {
  id        String     @id @default(cuid())
  clinicId  String
  name      String
  email     String?
  /// E.164 obrigatório (validado por normalizePhoneBR em src/app/painel/pacientes/lib/schema.ts).
  /// A Fase 4 (Júlia) faz lookup por phone no webhook do WhatsApp — não pode ser null.
  phone     String
  cpf       String?
  birthDate DateTime?
  tag       PatientTag @default(NOVO)
  notes     String?    @db.Text

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([clinicId, tag])
  @@index([clinicId, phone])
}

// ── Agendamentos (escopo MVP) ────────────────────────────────────

enum AppointmentStatus {
  CONFIRMADO
  PENDENTE
  ATENDIDO
  CANCELADO
  AUSENTE
}

model Appointment {
  id             String            @id @default(cuid())
  clinicId       String
  patientId      String
  professionalId String?
  procedureId    String
  startsAt       DateTime
  durationMin    Int               @default(60)
  status         AppointmentStatus @default(PENDENTE)
  /// preço cobrado nesse atendimento (pode divergir da tabela do Procedure)
  priceBRL       Decimal?          @db.Decimal(10, 2)
  notes          String?           @db.Text
  /// horário do primeiro agendamento, antes de qualquer reagendamento.
  /// null = nunca foi reagendado. Set apenas no PRIMEIRO reschedule.
  originalStartsAt DateTime?
  /// timestamp do último reschedule. null = nunca reagendado.
  rescheduledAt    DateTime?

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  procedure    Procedure     @relation(fields: [procedureId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, startsAt])
  @@index([patientId])
  @@index([professionalId])
}

// ── Conversas WhatsApp (Júlia) ───────────────────────────────────

enum MessageSender {
  JULIA
  PATIENT
  HUMAN
}

model Conversation {
  id            String   @id @default(cuid())
  clinicId      String
  patientId     String
  /// preview da última mensagem (denormalizado pra lista lateral)
  lastPreview   String   @default("")
  lastMessageAt DateTime @default(now())
  unread        Int      @default(0)

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient  Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId, lastMessageAt])
  @@index([patientId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  sender         MessageSender
  text           String        @db.Text
  sentAt         DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
}

// ── Subscription (placeholder, ligar Stripe depois) ──────────────

enum SubscriptionPlan {
  TRIAL
  ESSENCIAL
  CLINICA
  REDE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model Subscription {
  id                   String             @id @default(cuid())
  clinicId             String             @unique
  plan                 SubscriptionPlan   @default(TRIAL)
  status               SubscriptionStatus @default(TRIAL)
  /// IDs do Stripe quando for ligado
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Audit log (LGPD compliance basics) ───────────────────────────

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  clinicId     String?
  action       String // ex: "lead.create", "lead.approve", "user.login"
  resourceType String?
  resourceId   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}
